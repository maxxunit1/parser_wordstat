# API Key из Yandex Cloud AI Studio (НЕ OAuth-токен)
# Получить: https://aistudio.yandex.ru → API Keys
# Формат: AQVN... или аналогичный
YANDEX_API_KEY=your_api_key_here

# Folder ID из Yandex Cloud (опционально, но рекомендуется)
# Получить: Yandex Cloud Console → выбрать каталог → скопировать ID
# Формат: b1g...
YANDEX_FOLDER_ID=your_folder_id_here
